# Neon Postgres connection string (lấy từ https://console.neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT secret để ký token đăng nhập admin (tạo chuỗi ngẫu nhiên dài)
JWT_SECRET=change_me_to_a_long_random_string

# Tài khoản admin mặc định khi chạy `npm run db:seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Zalo của shop để khách liên hệ mua hàng (số điện thoại không có +84, dùng 0xxxx)
# Ví dụ: VITE_ZALO_PHONE=0987654321
# Có thể đặt link đầy đủ qua VITE_ZALO_URL nếu bạn dùng Zalo OA
VITE_ZALO_PHONE=
VITE_ZALO_URL=
