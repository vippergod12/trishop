# Neon Postgres connection string (lấy từ https://console.neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT secret để ký token đăng nhập admin (tạo chuỗi ngẫu nhiên dài)
JWT_SECRET=change_me_to_a_long_random_string

# Tài khoản admin mặc định khi chạy `npm run db:seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
