# Neon Postgres connection string (lấy từ https://console.neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT secret để ký token đăng nhập admin (tạo chuỗi ngẫu nhiên dài)
JWT_SECRET=change_me_to_a_long_random_string

# Tài khoản admin mặc định khi chạy `npm run db:seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Zalo của shop để khách liên hệ mua hàng (số điện thoại không có +84, dùng 0xxxx)
# Trên Next.js, biến cho client phải có prefix NEXT_PUBLIC_.
# Ví dụ: NEXT_PUBLIC_ZALO_PHONE=0987654321
# Có thể đặt link đầy đủ qua NEXT_PUBLIC_ZALO_URL nếu dùng Zalo OA.
NEXT_PUBLIC_ZALO_PHONE=
NEXT_PUBLIC_ZALO_URL=

# Domain production (KHÔNG có dấu / cuối) — dùng cho canonical, OG, sitemap.
# Ví dụ: NEXT_PUBLIC_SITE_URL=https://trishop.vn
# Trên Vercel: chỉ cần set NEXT_PUBLIC_SITE_URL — server (sitemap, fetcher)
# cũng sẽ đọc giá trị này, fallback sang VERCEL_URL nếu chưa set.
NEXT_PUBLIC_SITE_URL=

# Bí mật bảo vệ endpoint /api/_warm (cron giữ DB warm). Để trống nếu chưa dùng.
WARM_SECRET=
